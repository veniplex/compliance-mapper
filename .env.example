# Server port (default: 3000)
PORT=3000

# Comma-separated list of valid API keys.
# When set, all /api/* requests must include a matching key
# in the "x-api-key" request header.
# Leave unset (or remove this line) to disable key enforcement.
# API_KEYS=your-api-key-here,another-api-key

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_mapper
DB_USER=postgres
DB_PASSWORD=your-db-password
# Set DB_SSL=true when connecting to a hosted database that requires SSL
DB_SSL=false

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Number of bcrypt rounds for password hashing (default: 12, higher = slower but more secure)
# BCRYPT_ROUNDS=12
