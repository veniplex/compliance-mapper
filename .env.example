# Server port (default: 3000)
PORT=3000

# ── Standalone mode ───────────────────────────────────────────────────────────
# Set to true to run without a database. When enabled, all auth, progress, and
# API key features are disabled, and the API is fully open (no key enforcement).
# STANDALONE_MODE=false

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_mapper
DB_USER=postgres
DB_PASSWORD=your-db-password
# Set DB_SSL=true when connecting to a hosted database that requires SSL
DB_SSL=false

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Number of bcrypt rounds for password hashing (default: 12, higher = slower but more secure)
# BCRYPT_ROUNDS=12
